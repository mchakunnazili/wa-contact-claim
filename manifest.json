{
  "name": "Claim WA",
  "short_name": "ClaimWA",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#25D366",

  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    }
  ],

  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "contact",
          "accept": [
            ".vcf",
            "text/vcard"
          ]
        }
      ]
    }
  }
}
